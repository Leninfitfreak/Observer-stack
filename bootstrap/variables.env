# Core
PROJECT_NAME=LeninKart
ENVIRONMENT_NAME=dev
SERVICE_NAMES=frontend,auth-service,product-service,order-service,otel-collector
SIGNOZ_BASE_URL=http://127.0.0.1:8080

# SigNoz auth
# Leave blank to prefer Vault. The bootstrap will also check the workspace root .env.
SIGNOZ_API_KEY=
VAULT_ENABLED=true
VAULT_NAMESPACE=vault
VAULT_POD_NAME=vault-0
VAULT_SIGNOZ_SECRET_PATH=secret/leninkart/observability
VAULT_SIGNOZ_SECRET_FIELD=signoz_api_key

# Readiness
READY_CHECK_ATTEMPTS=30
READY_CHECK_INTERVAL_SECONDS=10

# Notifications
ENABLE_EMAIL_ALERTS=false
ENABLE_SLACK_ALERTS=false
ALERT_EMAIL=
SLACK_WEBHOOK=
SLACK_CHANNEL=

# Alert feature flags
ENABLE_METRIC_ALERTS=true
ENABLE_LOG_ALERTS=true

# Thresholds
LATENCY_THRESHOLD=500
ERROR_RATE_THRESHOLD=5
CPU_THRESHOLD=80
MEMORY_THRESHOLD=536870912
KAFKA_LAG_THRESHOLD=100
NO_TRAFFIC_THRESHOLD=1

# Evaluation defaults
DEFAULT_EVAL_WINDOW=5m0s
DEFAULT_EVAL_FREQUENCY=1m
