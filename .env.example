# Required central platform settings
DATABASE_URL=postgresql+psycopg://ai_observer:ai_observer_pw@postgres:5432/ai_observer
DB_ECHO_SQL=false

# Postgres connection variables used by docker-compose
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ai_observer
DB_USER=ai_observer
DB_PASSWORD=change-me

# Multi-cluster ingest auth
AGENT_TOKEN=replace-me-dev-token
AGENT_CLUSTER_ID=docker-local
AGENT_CENTRAL_URL=http://backend:8080/api/agent/push
AGENT_PROM_URL=http://prometheus:9090
AGENT_PUSH_INTERVAL=15
AGENT_ENVIRONMENT=dev

# Optional defaults for API behavior
CLUSTER_ID=default-cluster
DEFAULT_NAMESPACE=default
DEFAULT_SERVICE=all
DEFAULT_SEVERITY=warning
DEFAULT_WINDOW_MINUTES=30

# External observability endpoints via Kubernetes NGINX ingress
OBSERVABILITY_INGRESS_HOST=minikube
PROMETHEUS_URL=http://minikube/prometheus
LOKI_URL=http://minikube/loki
JAEGER_URL=http://minikube/jaeger

# Discovery / connectivity validation controls
KUBERNETES_ENABLED=true
KUBERNETES_NAMESPACE=dev
OBS_DISCOVERY_ENABLED=true
DISCOVERY_NAMESPACES=dev
K8S_API_URL=https://kubernetes.default.svc
K8S_VERIFY_SSL=true
OBS_DISCOVERY_REFRESH_SECONDS=60
OBS_DISCOVERY_VALIDATION_TIMEOUT_SECONDS=3

# LLM settings
LLM_PROVIDER=ollama
LLM_MODEL=gpt-oss:120b-cloud
LLAMA_API_URL=https://ollama.com
LLAMA_API_KEY=
LLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_URL=https://ollama.com
OLLAMA_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# HTTP client settings
HTTP_TIMEOUT_SECONDS=30
HTTP_ATTEMPTS=3

# Incident-driven detection/reasoning controls
INCIDENT_DETECTION_ENABLED=true
INCIDENT_DETECTION_INTERVAL=30
ANOMALY_THRESHOLD=0.65
SERVICE_DISCOVERY_MODE=auto
